    <script>
        const PROFESIONAL_EMAIL = "wildaoneillcorpus@gmail.com";
        let state = {
            dep: { energy: 5, tasks: [] },
            ans: { thoughts: [] },
            aut: { records: [], logros: [] },
            est: { urgent: "" }
        };
        let currentTarget = '';

        function showView(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`view-${id}`).classList.remove('hidden');
        }

        function openModule(mod) {
            showView(mod);
            if(mod === 'esperanza') renderDep();
            if(mod === 'autoestima') renderAut();
        }

        function toggleSOS() {
            const sosView = document.getElementById('view-sos');
            sosView.classList.toggle('hidden');
        }

        function startSOSCycle() {
            const circle = document.getElementById('sos-circle');
            const timer = document.getElementById('sos-timer');
            const inst = document.getElementById('sos-instruction');
            const btn = document.getElementById('sos-start-btn');
            const msgs = ["Inhala (Nariz)", "Mantén (Pulmones llenos)", "Exhala (Boca - Despacio)"];
            const calmingMessages = [
                "Tu corazón está fuerte, solo está bombeando.",
                "Esto es adrenalina, pasará pronto.",
                "Estás seguro aquí y ahora.",
                "Confía en tu respiración."
            ];
            
            btn.disabled = true;
            let cycle = 0;

            const run = () => {
                const phase = cycle % 3;
                inst.innerText = msgs[phase];
                document.getElementById('sos-message').innerText = calmingMessages[Math.floor(Math.random() * calmingMessages.length)];
                
                if (phase === 0) {
                    circle.classList.add('inhale');
                    circle.classList.remove('exhale');
                    countDown(4);
                } else if (phase === 1) {
                    countDown(4);
                } else {
                    circle.classList.add('exhale');
                    circle.classList.remove('inhale');
                    countDown(8);
                }
                
                cycle++;
                if(cycle < 9) {
                    setTimeout(run, phase === 2 ? 8000 : 4000);
                } else {
                    btn.disabled = false;
                    inst.innerText = "Ciclo de emergencia completado.";
                    btn.innerText = "Reiniciar si es necesario";
                }
            };

            const countDown = (num) => {
                let current = num;
                timer.innerText = current;
                const cInt = setInterval(() => {
                    current--;
                    timer.innerText = current;
                    if(current <= 0) clearInterval(cInt);
                }, 1000);
            };

            run();
        }

        function startStandardBreathing() {
            const btn = document.getElementById('std-breath-btn');
            btn.disabled = true;
            let step = 0;
            const ph = ["INHALA (4s)", "MANTÉN (4s)", "EXHALA (8s)"];
            const intv = setInterval(() => {
                btn.innerText = ph[step % 3];
                step++;
                if(step > 9) { clearInterval(intv); btn.innerText = "EJERCICIO COMPLETADO"; btn.disabled = false; }
            }, 4000);
        }

        function renderDep() {
            const l = document.getElementById('dep-tasks');
            l.innerHTML = state.dep.tasks.map((t, i) => `
                <div onclick="state.dep.tasks[${i}].d=!state.dep.tasks[${i}].d;renderDep()" class="p-4 bg-slate-50 rounded-xl flex items-center justify-between cursor-pointer">
                    <span class="text-xs font-bold ${t.d ? 'line-through text-slate-400' : ''}">${t.n}</span>
                    <i class="fas ${t.d ? 'fa-check-circle text-indigo-500' : 'fa-circle text-slate-200'}"></i>
                </div>
            `).join('');
        }

        function renderAut() {
            const l = document.getElementById('aut-logros');
            l.innerHTML = state.aut.logros.map(t => `<div class="p-3 bg-rose-50 rounded-xl text-xs font-bold text-rose-900 border border-rose-100">${t.n}</div>`).join('');
        }

        function openInputModal(t) { currentTarget = t; document.getElementById('modal-input').classList.replace('hidden', 'flex'); }
        function closeModal() { document.getElementById('modal-input').classList.replace('flex', 'hidden'); }

        function confirmInput() {
            const v = document.getElementById('modal-field').value;
            if(!v) return;
            if(currentTarget === 'dep') { state.dep.tasks.push({n: v, d: false}); renderDep(); }
            if(currentTarget === 'aut') { state.aut.logros.push({n: v}); renderAut(); }
            closeModal();
            document.getElementById('modal-field').value = '';
        }

        function saveIdentity() {
            const c = document.getElementById('aut-critica').value;
            const v = document.getElementById('aut-verdad').value;
            if(!c || !v) return;
            state.aut.records.push({c, v});
            document.getElementById('aut-critica').value = '';
            document.getElementById('aut-verdad').value = '';
            alert("Nueva creencia consolidada en la corteza prefrontal.");
        }

        function applyDefusion() {
            const el = document.getElementById('ans-thought');
            if(!el.value) return;
            el.value = `Noto que mi mente me está diciendo que: "${el.value}"`;
            state.ans.thoughts.push(el.value);
        }

        function sendMasterReport() {
            let b = `REPORTE VITALMENTE - SEGUIMIENTO INTEGRAL\nDra. Wilda O’neill Corpus\n\n`;
            b += `1. ESPERANZA: Energía ${state.dep.energy}/10. Metas: ${state.dep.tasks.filter(t=>t.d).length}/${state.dep.tasks.length}.\n`;
            b += `2. CALMA PRO: Pensamientos procesados: ${state.ans.thoughts.length}.\n`;
            b += `3. FORTALEZA: Victorias: ${state.aut.logros.length}. Nuevas creencias: ${state.aut.records.length}.\n`;
            b += `4. RESILIENCIA: Tareas urgentes registradas.\n`;
            window.location.href = `mailto:${PROFESIONAL_EMAIL}?subject=Seguimiento Terapéutico VitalMente&body=${encodeURIComponent(b)}`;
        }
    </script>
</body>
</html>

